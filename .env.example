# =============================================================================
# Stock Tracker — local environment overrides.
#
# Copy this file to `.env` (in the same folder) and fill in real values.
# `.env` is gitignored and read automatically by run-prod.ps1 before Java
# starts; install-service.ps1 reads it too when registering the Windows
# service. The application itself never reads .env directly — values are
# injected as ordinary environment variables, so Spring resolves
# ${DB_PASSWORD} / ${JWT_SECRET} the way it always has.
#
# Format: KEY=VALUE per line. Quotes are optional but recommended for
# values containing spaces or shell metacharacters. Lines starting with
# `#` are comments. Whitespace around `=` is trimmed.
# =============================================================================

# Postgres role used by the backend. Must match what `ALTER USER postgres
# WITH PASSWORD '...'` set in your local Postgres instance.
DB_PASSWORD='change-me'

# Random base64 secret used to sign JWTs. 32+ bytes recommended. Generate one
# with:  [Convert]::ToBase64String((New-Object byte[] 48 | %{ $_ }; ...))
# or just let install-service.ps1 generate it for you on first run.
JWT_SECRET='change-me-too'

# Optional overrides — only set these if you want to deviate from defaults.
# DB_URL=jdbc:postgresql://localhost:5432/stock_tracker
# DB_USERNAME=postgres
# SERVER_PORT=8080

# Comma-separated CORS allow-list, no spaces. Defaults already include the
# two React dev servers and any *.trycloudflare.com quick-tunnel URL; only
# set this when you have a permanent public hostname to add.
# APP_CORS_ORIGINS=http://localhost:5173,https://stocks.example.com

# SMTP, only needed when NOTIFICATION_CHANNEL=email.
# NOTIFICATION_CHANNEL=email
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=you@example.com
# MAIL_PASSWORD=app-specific-password
